    def generate_full_report(self):
        if self.df is None:
            return
        failure_rate = self.df["Machine failure"].mean()
        top_corr = self.df.select_dtypes(include=np.number).corr(numeric_only=True)["Machine failure"].drop("Machine failure").sort_values(key=np.abs, ascending=False).head(5)
        lines = [
            "КРАТКИЙ ОТЧЕТ ПО AI4I 2020",
            "",
            f"Наблюдений: {len(self.df)}",
            f"Признаков: {self.df.shape[1]}",
            f"Доля отказов: {failure_rate:.2%}",
            "",
            "Ключевые связи с Machine failure:",
        ]
        for name, val in top_corr.items():
            lines.append(f"- {name}: r = {val:.3f}")
        if self.feature_importances_ is not None:
            lines += ["", "Топ-5 важных признаков модели:"]
            for name, val in self.feature_importances_.head(5).items():
                lines.append(f"- {name}: {val:.4f}")
        lines += [
            "",
            "Практический вывод:",
            "датасет подходит для оценки риска отказа оборудования, сравнения режимов работы машин разных типов и демонстрации методов интеллектуального анализа данных."
        ]
        self.write_text("\n".join(lines))
        self.set_status("Общий отчет сформирован")

