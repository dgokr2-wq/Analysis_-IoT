    def run_anova(self):
        if self.df is None:
            return
        if "Type" not in self.df.columns:
            return
        col = "Torque [Nm]"
        groups = [g[col].values for _, g in self.df.groupby("Type")]
        stat, p = f_oneway(*groups)
        text = (
            "3.2. Проверка гипотезы ANOVA\n\n"
            "H0: среднее значение Torque [Nm] одинаково для машин типов L, M и H.\n"
            "H1: хотя бы для одного типа среднее значение Torque [Nm] отличается.\n\n"
            f"F-statistic = {stat:.4f}\n"
            f"p-value = {p:.6f}\n\n"
            + ("Вывод: H0 отвергается, различия статистически значимы." if p < 0.05 else "Вывод: нет оснований отвергнуть H0.")
        )
        self.write_text(text)
        self.set_status("ANOVA выполнена")

    def run_chi_square(self):
        if self.df is None or "Type" not in self.df.columns or "Machine failure" not in self.df.columns:
            return
        table = pd.crosstab(self.df["Type"], self.df["Machine failure"])
        chi2, p, dof, _ = chi2_contingency(table)
        out = table.reset_index()
        self._update_table(out)
        text = (
            "3.2. Проверка гипотезы хи-квадрат\n\n"
            "H0: тип машины и факт отказа независимы.\n"
            "H1: между типом машины и фактом отказа есть статистическая связь.\n\n"
            f"chi2 = {chi2:.4f}\n"
            f"p-value = {p:.6f}\n"
            f"degrees of freedom = {dof}\n\n"
            + ("Вывод: H0 отвергается." if p < 0.05 else "Вывод: нет оснований отвергнуть H0.")
        )
        self.write_text(text)
        self.set_status("Хи-квадрат выполнен")

    def run_anomaly_detection(self):
        if self.df is None:
            return
        cols = ["Air temperature [K]", "Process temperature [K]", "Rotational speed [rpm]", "Torque [Nm]", "Tool wear [min]"]
        X = self.df[cols].copy()
        model = IsolationForest(contamination=0.03, random_state=42)
        pred = model.fit_predict(X)
        self.df["Anomaly"] = (pred == -1).astype(int)
        anom_count = int(self.df["Anomaly"].sum())
        self.ax.clear()
        self.ax.scatter(self.df["Rotational speed [rpm]"], self.df["Torque [Nm]"], c=self.df["Anomaly"])
        self.ax.set_title("Аномалии: Rotational speed vs Torque")
        self.ax.set_xlabel("Rotational speed [rpm]")
        self.ax.set_ylabel("Torque [Nm]")
        self.last_plot_name = "anomalies"
        self.fig.tight_layout()
        self.canvas.draw()
        self.write_text(
            "3.3. Поиск аномалий\n\n"
            f"Isolation Forest выявил {anom_count} потенциально аномальных наблюдений "
            f"({anom_count / len(self.df):.2%} выборки).\n"
            "Эти наблюдения можно интерпретировать как нетипичные режимы работы оборудования."
        )
        self.set_status("Поиск аномалий выполнен")

    def train_model(self):
        if self.df is None:
            return
        work = self.df.copy()
        y = work["Machine failure"]
        X = work.drop(columns=["Machine failure", "UDI", "Product ID", "TWF", "HDF", "PWF", "OSF", "RNF"], errors="ignore")
        X = pd.get_dummies(X, columns=["Type"], drop_first=True)
        self.model_features = X.columns.tolist()
        X_train, X_test, y_train, y_test = train_test_split(
            X, y, test_size=0.25, random_state=42, stratify=y
        )
        model = RandomForestClassifier(
            n_estimators=250, random_state=42, class_weight="balanced_subsample"
        )
        model.fit(X_train, y_train)
        pred = model.predict(X_test)
        proba = model.predict_proba(X_test)[:, 1]
        auc = roc_auc_score(y_test, proba)
        report = classification_report(y_test, pred, digits=4)
        cm = confusion_matrix(y_test, pred)
        self.model = model
        self.feature_importances_ = pd.Series(model.feature_importances_, index=X.columns).sort_values(ascending=False)

        text = (
            "3.3. Построение модели прогнозирования отказа\n\n"
            "Использована модель Random Forest.\n"
            f"Train size: {len(X_train)}, test size: {len(X_test)}\n"
            f"ROC-AUC: {auc:.4f}\n\n"
            "Матрица ошибок:\n"
            f"{cm}\n\n"
            "Classification report:\n"
            f"{report}\n"
            "Интерпретация: модель можно использовать для оценки риска отказа и анализа значимости факторов."
        )
        self.write_text(text)
        self.set_status("Модель обучена")

    def plot_feature_importance(self):
        if self.feature_importances_ is None:
            messagebox.showinfo("Нет модели", "Сначала обучи модель.")
            return
        top = self.feature_importances_.head(10).sort_values()
        self.ax.clear()
