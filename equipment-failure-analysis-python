    # ---------- Data ----------
    def _autoload_local_dataset(self):
        candidates = [
            self.base_dir / "ai4i2020.csv",
            self.base_dir / "AI4I 2020 Predictive Maintenance Dataset.csv",
            self.base_dir / "predictive_maintenance.csv",
        ]
        for path in candidates:
            if path.exists():
                self.load_csv(path)
                return
        messagebox.showinfo("Не найдено", "Положи ai4i2020.csv рядом с программой или используй кнопку 'Открыть CSV'.")

    def open_csv(self):
        path = filedialog.askopenfilename(filetypes=[("CSV files", "*.csv"), ("All files", "*.*")])
        if path:
            self.load_csv(Path(path))

    def load_csv(self, path: Path):
        try:
            df = pd.read_csv(path)
        except Exception as e:
            messagebox.showerror("Ошибка", f"Не удалось прочитать CSV:\n{e}")
            return
        self.df_raw = df.copy()
        self.df = df.copy()
        self.file_var.set(f"Загружен: {path.name}")
        self._update_table(self.df)
        self._update_meta()
        self.set_status("Датасет загружен")

    def reset_all(self):
        self.df_raw = None
        self.df = None
        self.model = None
        self.feature_importances_ = None
        self.model_features = []
        self.file_var.set("Файл не загружен")
        self.meta_var.set("Нет данных")
        self.tree.delete(*self.tree.get_children())
        self.text.delete("1.0", "end")
        self.ax.clear()
        self.ax.set_title("Здесь будут графики")
        self.canvas.draw()
        self.set_status("Сброс выполнен")

    def _update_meta(self):
        if self.df is None:
            self.meta_var.set("Нет данных")
            return
        self.meta_var.set(
            f"Строк: {len(self.df)}; столбцов: {self.df.shape[1]}; "
            f"пропусков: {int(self.df.isna().sum().sum())}; "
            f"дубликатов: {int(self.df.duplicated().sum())}; "
            f"доля отказов: {self.df['Machine failure'].mean():.2%}" if 'Machine failure' in self.df.columns else ""
        )

    def _update_table(self, data: pd.DataFrame, max_rows=300):
        self.tree.delete(*self.tree.get_children())
        if data is None or data.empty:
            return
        view = data.head(max_rows).copy()
        cols = list(view.columns)
        self.tree["columns"] = cols
        for c in cols:
            self.tree.heading(c, text=c)
            self.tree.column(c, width=120, anchor="center", stretch=True)
        for _, row in view.iterrows():
            vals = []
            for v in row.tolist():
                if pd.isna(v):
                    vals.append("NaN")
                elif isinstance(v, float):
                    vals.append(f"{v:.4f}")
                else:
                    vals.append(str(v))
            self.tree.insert("", "end", values=vals)

    def set_status(self, text):
        self.status_var.set(text)
        self.update_idletasks()

    def write_text(self, text, clear=True):
        if clear:
            self.text.delete("1.0", "end")
        self.text.insert("1.0", text)
        self.last_text = text

    def current_df(self):
