    # ---------- Section 2 ----------
    def run_preprocessing(self):
        if self.df is None:
            return
        df = self.df.copy()
        before_rows = len(df)
        before_dups = int(df.duplicated().sum())

        if self.drop_dups_var.get():
            df = df.drop_duplicates()

        # feature engineering
        if "Process temperature [K]" in df.columns and "Air temperature [K]" in df.columns:
            df["Temperature delta [K]"] = df["Process temperature [K]"] - df["Air temperature [K]"]
        if "Torque [Nm]" in df.columns and "Rotational speed [rpm]" in df.columns:
            df["Power proxy"] = df["Torque [Nm]"] * df["Rotational speed [rpm]"]
        if "Type" in df.columns:
            df["Type_code"] = LabelEncoder().fit_transform(df["Type"])

        if self.cap_outliers_var.get():
            numeric_cols = df.select_dtypes(include=np.number).columns
            for col in numeric_cols:
                q1 = df[col].quantile(0.25)
                q3 = df[col].quantile(0.75)
                iqr = q3 - q1
                if pd.isna(iqr) or iqr == 0:
                    continue
                lower, upper = q1 - 1.5 * iqr, q3 + 1.5 * iqr
                df[col] = df[col].clip(lower, upper)

        self.df = df
        self._update_table(self.df)
        self._update_meta()
        txt = (
            "2.1. Предобработка выполнена\n\n"
            f"Строк до обработки: {before_rows}\n"
            f"Строк после обработки: {len(df)}\n"
            f"Дубликатов до обработки: {before_dups}\n"
            f"Дубликатов после обработки: {int(df.duplicated().sum())}\n"
            f"Пропуски: {int(df.isna().sum().sum())} (в AI4I их изначально нет)\n\n"
            "Примененные действия:\n"
            f"- удаление дубликатов: {'да' if self.drop_dups_var.get() else 'нет'}\n"
            f"- ограничение выбросов по IQR: {'да' if self.cap_outliers_var.get() else 'нет'}\n"
            "- создание новых признаков: Temperature delta [K], Power proxy, Type_code\n\n"
            "Комментарий:\n"
            "Для этого датасета основная часть предобработки сводится не к заполнению пропусков, "
            "а к контролю качества данных, удалению возможных дублей и генерации аналитически полезных признаков."
        )
        self.write_text(txt)
        self.set_status("Предобработка завершена")

    def show_stats(self):
        if self.df is None:
            return
        num = self.df.select_dtypes(include=np.number)
        stats = num.describe().T
        stats["median"] = num.median()
        stats["variance"] = num.var()
        stats["missing"] = num.isna().sum()
        stats = stats.reset_index().rename(columns={"index": "feature"})
        self._update_table(stats)
        self.set_status("Сводная статистика готова")

    def _choose_numeric(self, title="Выбор признака", allow_two=False):
        cols = self.df.select_dtypes(include=np.number).columns.tolist() if self.df is not None else []
        if not cols:
            return None if not allow_two else (None, None)
        d = tk.Toplevel(self)
        d.title(title)
        d.geometry("360x170" if allow_two else "320x130")
        d.transient(self)
        d.grab_set()
        if allow_two:
            x_var = tk.StringVar(value=cols[0])
            y_var = tk.StringVar(value=cols[1] if len(cols) > 1 else cols[0])
            ttk.Label(d, text="X").pack(anchor="w", padx=12, pady=(12, 2))
            ttk.Combobox(d, values=cols, textvariable=x_var, state="readonly").pack(fill="x", padx=12)
            ttk.Label(d, text="Y").pack(anchor="w", padx=12, pady=(8, 2))
            ttk.Combobox(d, values=cols, textvariable=y_var, state="readonly").pack(fill="x", padx=12)
            out = {"x": None, "y": None}
            ttk.Button(d, text="OK", command=lambda: (out.update({"x": x_var.get(), "y": y_var.get()}), d.destroy())).pack(pady=12)
            self.wait_window(d)
            return out["x"], out["y"]
        else:
            var = tk.StringVar(value=cols[0])
            ttk.Label(d, text="Выбери признак").pack(pady=(12, 4))
            ttk.Combobox(d, values=cols, textvariable=var, state="readonly").pack(fill="x", padx=12)
            out = {"v": None}
            ttk.Button(d, text="OK", command=lambda: (out.update({"v": var.get()}), d.destroy())).pack(pady=12)
            self.wait_window(d)
            return out["v"]

