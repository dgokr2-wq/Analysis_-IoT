    def generate_eda_text(self):
        if self.df is None:
            return
        num = self.df.select_dtypes(include=np.number)
        corr = num.corr(numeric_only=True)
        pairs = []
        cols = corr.columns.tolist()
        for i in range(len(cols)):
            for j in range(i + 1, len(cols)):
                pairs.append((cols[i], cols[j], corr.iloc[i, j]))
        pairs = sorted(pairs, key=lambda t: abs(t[2]), reverse=True)[:5]
        lines = [
            "2.2. Выводы по разведочному анализу данных\n",
            f"1) В наборе {len(self.df)} наблюдений и {self.df.shape[1]} признаков.",
            f"2) Доля отказов оборудования составляет {self.df['Machine failure'].mean():.2%}.",
            "3) Основные количественные признаки хорошо подходят для сравнения распределений и построения моделей.",
            "4) Наиболее сильные корреляционные связи:",
        ]
        for a, b, r in pairs:
            lines.append(f"   - {a} ↔ {b}: r = {r:.3f}")
        lines += [
            "5) Визуализация распределений позволяет выявить асимметрию и потенциальные выбросы, особенно по torque, rotational speed и tool wear.",
            "6) Для дальнейшего анализа целесообразно использовать статистические критерии и модель классификации отказов."
        ]
        self.write_text("\n".join(lines))
        self.set_status("Сформирован текст выводов по EDA")

